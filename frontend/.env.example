# Copy to .env.local for local dev. NEXT_PUBLIC_* vars are exposed to the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Clerk authentication (Phase 2) ---
# Create an app at https://dashboard.clerk.com and copy the keys from "API keys".
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth route locations + post-auth landing page.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
