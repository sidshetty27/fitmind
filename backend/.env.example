# Copy to .env and fill in. .env is git-ignored.

# App
ENVIRONMENT=development

# Comma-separated origins allowed to call this API (the Next.js frontend)
CORS_ORIGINS=http://localhost:3000

# ---------- Database (Phase 3) ----------
# Supabase → Project Settings → Database → Connection string.
#
# DATABASE_URL: runtime connection, use the **Transaction pooler** (port 6543).
#   Short-lived, per-request connections are exactly what it is built for.
# MIGRATION_DATABASE_URL: Alembic, use the **Direct connection** (port 5432).
#   DDL needs session-level state that the transaction pooler cannot hold.
#
# The scheme is normalised to postgresql+psycopg:// automatically — paste the
# URL exactly as Supabase gives it to you. URL-encode any special characters in
# the password (@ → %40, # → %23, etc.).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
MIGRATION_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# Local Postgres instead of Supabase? One URL is enough — leave
# MIGRATION_DATABASE_URL unset and it falls back to DATABASE_URL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fitmind

# Log every SQL statement (useful while learning, far too noisy in production)
DB_ECHO=false
