# Copy to .env and fill in. .env is git-ignored.

# App
ENVIRONMENT=development

# Comma-separated origins allowed to call this API (the Next.js frontend)
CORS_ORIGINS=http://localhost:3000

# ---------- Database (Phase 3) ----------
# Supabase → Project Settings → Database → Connection string.
#
# DATABASE_URL: runtime connection, use the **Transaction pooler** (port 6543).
#   Short-lived, per-request connections are exactly what it is built for.
# MIGRATION_DATABASE_URL: Alembic, use the **Direct connection** (port 5432).
#   DDL needs session-level state that the transaction pooler cannot hold.
#
# The scheme is normalised to postgresql+psycopg:// automatically — paste the
# URL exactly as Supabase gives it to you. URL-encode any special characters in
# the password (@ → %40, # → %23, etc.).
DATABASE_URL=postgresql://postgres.wgbdoaqoxwrtrlzllyqq:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:6543/postgres
MIGRATION_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.wgbdoaqoxwrtrlzllyqq.supabase.co:5432/postgres

# Local Postgres instead of Supabase? One URL is enough — leave
# MIGRATION_DATABASE_URL unset and it falls back to DATABASE_URL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fitmind

# Log every SQL statement (useful while learning, far too noisy in production)
DB_ECHO=false

# ---------- Clerk authentication (Phase 4) ----------
# The backend verifies the Clerk session JWT the frontend sends — it does not call
# Clerk on the hot path.
#
# CLERK_ISSUER: your "Frontend API URL" from Clerk Dashboard → API keys, e.g.
#   https://your-app.clerk.accounts.dev (dev) or https://clerk.yourdomain.com (prod).
#   JWKS is fetched from {issuer}/.well-known/jwks.json automatically.
CLERK_ISSUER=https://your-app.clerk.accounts.dev
# CLERK_JWKS_URL: only set to override the derived URL above.
# CLERK_JWKS_URL=

# Optional hardening: restrict the token's `azp` (origin) claim to your frontends.
# Comma-separated; leave blank to disable the check.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Recommended: add an `email` (and optionally `name`) claim to your Clerk JWT
# template so the API can provision users with zero extra calls. If you do, the
# secret key below is not needed. See backend/README.md.
#
# CLERK_SECRET_KEY: only used as a fallback to fetch a user's email when the token
# carries none. Clerk Dashboard → API keys → Secret key (sk_...).
# CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CLERK_WEBHOOK_SECRET: Svix signing secret for the user-sync webhook. Create the
# endpoint in Clerk Dashboard → Webhooks (point it at /api/webhooks/clerk,
# subscribe to user.created/updated/deleted) and copy its "Signing Secret".
# CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
